---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import { useTranslations } from '../i18n/ui';
import type { Locale } from '../i18n/languages';

interface Props {
  title?: string;
  description?: string;
}

const locale = (Astro.currentLocale ?? 'fr') as Locale;
const t = useTranslations(locale);

const { title = t('layout.title'), description = t('layout.description') } = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Hreflang SEO -->
    <link rel="alternate" hreflang="fr" href="https://devteix.com/" />
    <link rel="alternate" hreflang="en" href="https://devteix.com/en/" />
    <link rel="alternate" hreflang="x-default" href="https://devteix.com/" />

    <!-- Google Fonts - IBM Plex Sans (corps) + Bricolage Grotesque (titres) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet">

    <!-- AOS CSS -->
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">
  </head>
  <body class="min-h-screen antialiased">
    <slot />
    <Analytics />

    <!-- AOS JS -->
    <script is:inline src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        if (typeof AOS !== 'undefined') {
          AOS.init({
            duration: 400,
            easing: 'ease-out',
            once: true,
            offset: 30,
          });
        }
      });
    </script>
  </body>
</html>
