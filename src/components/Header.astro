---
import { useTranslations, getNavItems, getFooterProducts } from '../i18n/ui';
import type { Locale } from '../i18n/languages';
import { Image } from 'astro:assets';

const locale = (Astro.currentLocale ?? 'fr') as Locale;
const t = useTranslations(locale);
const navItems = getNavItems(locale);
const homeUrl = locale === 'fr' ? '/' : '/en/';
const currentPath = Astro.url.pathname;
const isHomePage = currentPath === homeUrl;
const steelUrl = locale === 'fr' ? 'https://steel-manager.be/fr/' : 'https://steel-manager.be/en/';
const woodUrl = locale === 'fr' ? 'https://wood-manager.be/fr/' : 'https://wood-manager.be/en/';

function resolveNavHref(href: string) {
  if (href.startsWith('#')) {
    return isHomePage ? href : `${homeUrl}${href}`;
  }
  return href;
}
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-border/50 transition-all duration-150">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16 lg:h-18">
      <!-- Logo -->
      <a href={homeUrl} class="flex items-center relative z-10 shrink-0">
        <Image
          src="/images/DevTeix.png"
          alt="DevTeix"
          width={140}
          height={35}
          loading="eager"
          style="height: 35px; width: auto;"
        />
      </a>

      <!-- Navigation Desktop -->
      <nav class="hidden lg:flex items-center gap-0.5">
        {navItems.map((item) => (
          <a
            href={resolveNavHref(item.href)}
            class="nav-link px-3 py-2 text-dark hover:text-primary text-sm font-medium transition-colors rounded-md hover:bg-primary/5"
            data-nav-link
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Product logos + Lang switch + CTA Desktop -->
      <div class="hidden lg:flex items-center gap-2">
        <div class="product-links">
          <a
            href={steelUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="product-link"
            title="Steel Manager"
          >
            <Image src="/images/logo-steel-manager.png" alt="Steel Manager" width={200} height={80} loading="eager" style="height: 101px; width: auto;" />
          </a>
          <a
            href={woodUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="product-link"
            title="Wood Manager"
          >
            <Image src="/images/logo-wood-manager.png" alt="Wood Manager" width={120} height={45} loading="eager" style="height: 56px; width: auto;" />
          </a>
        </div>

        <!-- Language switcher -->
        <div class="flex items-center border border-border rounded-md overflow-hidden text-sm ml-1">
          <a
            href="/"
            class:list={[
              'px-2.5 py-1.5 font-medium transition-colors',
              locale === 'fr' ? 'bg-primary text-white' : 'text-text-light hover:bg-light'
            ]}
          >FR</a>
          <a
            href="/en/"
            class:list={[
              'px-2.5 py-1.5 font-medium transition-colors',
              locale === 'en' ? 'bg-primary text-white' : 'text-text-light hover:bg-light'
            ]}
          >EN</a>
        </div>

        <a
          href="#contact"
          class="btn btn-primary text-sm ml-1 whitespace-nowrap px-4"
        >
          {t('header.cta')}
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden relative z-10 p-2 rounded-md text-dark hover:bg-light transition-colors"
        aria-label="Menu"
      >
        <svg id="menu-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden absolute top-full left-0 right-0 bg-white border-b border-border shadow-lg">
    <div class="px-4 py-4 space-y-1">
        {navItems.map((item) => (
        <a
          href={resolveNavHref(item.href)}
          class="nav-link-mobile flex items-center justify-between px-4 py-3 text-dark hover:text-primary hover:bg-light rounded-md text-base font-medium transition-all"
          data-nav-link
        >
          {item.label}
          <svg class="mobile-link-arrow w-4 h-4 text-text-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ))}
      <div class="pt-4 space-y-3 border-t border-border mt-4">
        <!-- Mobile language switcher -->
        <div class="flex items-center justify-center gap-2 py-2">
          <div class="flex items-center border border-border rounded-md overflow-hidden text-sm">
            <a
              href="/"
              class:list={[
                'px-3 py-2 font-medium transition-colors',
                locale === 'fr' ? 'bg-primary text-white' : 'text-text-light hover:bg-light'
              ]}
            >FR</a>
            <a
              href="/en/"
              class:list={[
                'px-3 py-2 font-medium transition-colors',
                locale === 'en' ? 'bg-primary text-white' : 'text-text-light hover:bg-light'
              ]}
            >EN</a>
          </div>
        </div>
        <div class="flex items-center justify-center gap-6 py-2">
          <a href={steelUrl} target="_blank" rel="noopener noreferrer" title="Steel Manager">
            <Image src="/images/logo-steel-manager.png" alt="Steel Manager" width={70} height={28} style="height: 28px; width: auto;" />
          </a>
          <a href={woodUrl} target="_blank" rel="noopener noreferrer" title="Wood Manager">
            <Image src="/images/logo-wood-manager.png" alt="Wood Manager" width={70} height={28} style="height: 28px; width: auto;" />
          </a>
        </div>
        <a
          href="#contact"
          class="btn btn-accent block w-full text-center"
        >
          {t('header.cta')}
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-link.is-active {
    color: var(--color-primary);
    background: rgba(67, 97, 238, 0.08);
    position: relative;
  }

  .nav-link.is-active::after {
    content: "";
    position: absolute;
    left: 0.8rem;
    right: 0.8rem;
    bottom: 0.34rem;
    height: 2px;
    border-radius: 99px;
    background: linear-gradient(90deg, rgba(67, 97, 238, 0.92), rgba(6, 214, 160, 0.9));
  }

  .product-links {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .product-link {
    display: inline-flex;
    align-items: center;
    opacity: 0.9;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .product-link:hover {
    opacity: 1;
    transform: translateY(-1px);
  }

  .nav-link-mobile.is-active {
    color: var(--color-primary);
    background: rgba(67, 97, 238, 0.08);
  }

  .nav-link-mobile .mobile-link-arrow {
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .nav-link-mobile.is-active .mobile-link-arrow {
    color: var(--color-primary);
    transform: translateX(2px);
  }
</style>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuOpen = document.getElementById('menu-open');
  const menuClose = document.getElementById('menu-close');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    menuOpen?.classList.toggle('hidden');
    menuClose?.classList.toggle('hidden');
  });

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      menuOpen?.classList.remove('hidden');
      menuClose?.classList.add('hidden');
    });
  });

  const header = document.getElementById('header');

  window.addEventListener('scroll', () => {
    if (window.pageYOffset > 20) {
      header?.classList.add('shadow-sm');
    } else {
      header?.classList.remove('shadow-sm');
    }
  });

  function initScrollSpy() {
    const navLinks = Array.from(document.querySelectorAll('a[data-nav-link]')) as HTMLAnchorElement[];
    if (!navLinks.length) return;

    const sectionLinks = navLinks
      .map((link) => link.getAttribute('href') || '')
      .filter((href) => href.startsWith('#') && href.length > 1);
    const uniqueIds = Array.from(new Set(sectionLinks.map((href) => href.slice(1))));
    const sections = uniqueIds
      .map((id) => document.getElementById(id))
      .filter((section): section is HTMLElement => Boolean(section));

    if (!sections.length) return;

    let ticking = false;

    function setActive(id: string) {
      navLinks.forEach((link) => {
        const isActive = link.getAttribute('href') === `#${id}`;
        link.classList.toggle('is-active', isActive);
        if (isActive) {
          link.setAttribute('aria-current', 'page');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    }

    function updateActive() {
      const headerOffset = (header as HTMLElement | null)?.offsetHeight ?? 80;
      if (window.scrollY < headerOffset + 40) {
        navLinks.forEach((link) => {
          const href = link.getAttribute('href') || '';
          if (href.startsWith('#')) {
            link.classList.remove('is-active');
            link.removeAttribute('aria-current');
          }
        });
        ticking = false;
        return;
      }

      const marker = window.scrollY + headerOffset + 90;

      let currentId = sections[0].id;
      for (const section of sections) {
        if (section.offsetTop <= marker) {
          currentId = section.id;
        }
      }

      const scrollBottom = window.scrollY + window.innerHeight;
      const pageBottom = document.documentElement.scrollHeight - 4;
      if (scrollBottom >= pageBottom) {
        currentId = sections[sections.length - 1].id;
      }

      setActive(currentId);
      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(updateActive);
        ticking = true;
      }
    }

    navLinks.forEach((link) => {
      link.addEventListener('click', () => {
        const href = link.getAttribute('href');
        if (href?.startsWith('#')) {
          const id = href.slice(1);
          setActive(id);
        }
      });
    });

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    updateActive();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollSpy);
  } else {
    initScrollSpy();
  }
  document.addEventListener('astro:page-load', initScrollSpy);
</script>
