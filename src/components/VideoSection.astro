---
---

<section class="section-soft section-spacing overflow-hidden">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-10" data-aos="fade-up">
      <div class="badge badge-primary mb-4 mx-auto">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M6.3 2.84A1.5 1.5 0 004 4.11v11.78a1.5 1.5 0 002.3 1.27l9.344-5.891a1.5 1.5 0 000-2.538L6.3 2.84z" />
        </svg>
        <span>Présentation</span>
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold text-dark mb-3">
        Découvrez <span class="text-gradient">DevTeix</span> en action
      </h2>
      <p class="text-text-light text-lg max-w-2xl mx-auto">
        Une vue d'ensemble de notre approche et de nos solutions logicielles sur mesure.
      </p>
    </div>

    <!-- Video container -->
    <div
      class="relative rounded-xl overflow-hidden shadow-2xl shadow-primary/10"
      data-aos="fade-up"
      data-aos-delay="100"
    >
      <!-- Glow behind -->
      <div class="absolute -inset-4 -z-10 rounded-2xl" style="background: radial-gradient(ellipse at center, rgba(67,97,238,0.08) 0%, transparent 70%);"></div>

      <video
        class="w-full h-auto block rounded-xl"
        controls
        preload="metadata"
        poster=""
        style="aspect-ratio: 16/9; background: var(--color-dark);"
      >
        <source src="/video/devteixpres.web.mp4#t=1" type="video/mp4" />
        Votre navigateur ne supporte pas la lecture vidéo.
      </video>
    </div>

  </div>
</section>
